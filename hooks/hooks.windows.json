{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/on-test-hang.ps1\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/on-startup.ps1\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
